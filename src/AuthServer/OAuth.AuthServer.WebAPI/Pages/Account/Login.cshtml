@page
@model OAuth.AuthServer.WebAPI.Pages.Account.LoginModel
@{
    ViewData["Title"] = "登入";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: sans-serif; max-width: 400px; margin: 60px auto; padding: 0 20px; }
        h1 { color: #333; }
        .form-group { margin: 12px 0; }
        label { display: block; margin-bottom: 4px; font-weight: bold; }
        input { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        button { width: 100%; padding: 10px; background: #0078d4; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; margin-top: 16px; }
        button:hover { background: #005fa3; }
        .error { color: red; margin-bottom: 12px; }
        hr { margin: 20px 0; }
        .social-links a { display: inline-block; margin: 4px 8px 4px 0; padding: 6px 12px; background: #f0f0f0; border-radius: 4px; text-decoration: none; color: #333; }
        .social-links a:hover { background: #ddd; }
    </style>
</head>
<body>
    <h1>登入</h1>

    @if (Model.ErrorMessage is not null)
    {
        <p class="error">@Model.ErrorMessage</p>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        <div class="form-group">
            <label>帳號或 Email</label>
            <input type="text" name="userName" required autocomplete="username" />
        </div>
        <div class="form-group">
            <label>密碼</label>
            <input type="password" name="Password" required autocomplete="current-password" />
        </div>
        <button type="submit">登入</button>
    </form>

    <hr />
    <p>以社群帳號登入：</p>
    <div class="social-links">
        <a href="/connect/authorize/external?provider=Google&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "")">Google</a>
        <a href="/connect/authorize/external?provider=Microsoft&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "")">Microsoft</a>
        <a href="/connect/authorize/external?provider=Line&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "")">Line</a>
        <a href="/connect/authorize/external?provider=Facebook&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "")">Facebook</a>
        <a href="/connect/authorize/external?provider=Threads&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "")">Threads</a>
    </div>
</body>
</html>
