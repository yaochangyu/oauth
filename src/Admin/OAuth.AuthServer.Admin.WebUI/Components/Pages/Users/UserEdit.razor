@page "/users/edit/{Id}"
@rendermode InteractiveServer
@inject UserAdminService UserService
@inject RoleAdminService RoleService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Edit User</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_vm is null)
{
    <MudAlert Severity="Severity.Error">User not found.</MudAlert>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-4">Edit User: @_vm.UserName</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="4">
                <MudCardHeader><MudText Typo="Typo.h6">Info</MudText></MudCardHeader>
                <MudCardContent>
                    <MudTextField @bind-Value="_vm.UserName" Label="Username" ReadOnly="true" />
                    <MudTextField @bind-Value="_vm.Email" Label="Email" ReadOnly="true" Class="mt-2" />
                    <MudCheckBox @bind-Value="_vm.EmailConfirmed" Label="Email Confirmed" Disabled="true" />
                    <MudCheckBox @bind-Value="_vm.LockoutEnabled" Label="Lockout Enabled" Disabled="true" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton Color="Color.Warning" Variant="Variant.Outlined"
                               OnClick="ToggleLockoutAsync">
                        @(_vm.IsLockedOut ? "Unlock User" : "Lock User")
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="4">
                <MudCardHeader><MudText Typo="Typo.h6">Roles</MudText></MudCardHeader>
                <MudCardContent>
                    @foreach (var role in _allRoles)
                    {
                        var hasRole = _vm.UserRoles.Any(r => r.RoleName == role.RoleName);
                        <MudCheckBox Value="hasRole"
                                     ValueChanged="(bool v) => ToggleRoleAsync(role.RoleName, v)"
                                     Label="@role.RoleName" />
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
    <MudButton Class="mt-3" Variant="Variant.Text" OnClick='() => Nav.NavigateTo("/users")'>Back</MudButton>
}

@code {
    [Parameter] public string Id { get; set; } = default!;

    private UserDetailsViewModel? _vm;
    private List<UserRoleViewModel> _allRoles = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _vm = await UserService.GetByIdAsync(Id);
        _allRoles = RoleService.GetPaged(1, 100).Items.ToList();
        _loading = false;
    }

    private async Task ToggleLockoutAsync()
    {
        if (_vm is null) return;
        var locked = !_vm.IsLockedOut;
        var error = await UserService.SetLockoutAsync(Id, locked);
        if (error is null)
        {
            Snackbar.Add(locked ? "User locked." : "User unlocked.", Severity.Success);
            _vm = await UserService.GetByIdAsync(Id);
        }
        else Snackbar.Add(error, Severity.Error);
    }

    private async Task ToggleRoleAsync(string roleName, bool add)
    {
        string? error = add
            ? await UserService.AddToRoleAsync(Id, roleName)
            : await UserService.RemoveFromRoleAsync(Id, roleName);

        if (error is null)
        {
            Snackbar.Add($"Role {(add ? "added" : "removed")}.", Severity.Success);
            _vm = await UserService.GetByIdAsync(Id);
        }
        else Snackbar.Add(error, Severity.Error);
    }
}
